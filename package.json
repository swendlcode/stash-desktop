    "@tauri-apps/plugin-opener": "^2.0.0",
    "iconsax-reactjs": "^0.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
